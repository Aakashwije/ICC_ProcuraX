{
    "java.configuration.updateBuildConfiguration": "interactive",

    // Suppress false-positive "No such module 'Flutter'" in AppDelegate.swift.
    // The Flutter framework is only resolvable by Xcode's build system, not VS Code's Swift extension.
    "swift.diagnosticsCollection": "onlySourceKit",
    "swift.sourcekit-lsp.serverArguments": [],

    // Suppress false-positive Gradle sync error in android/build.gradle.kts.
    // Flutter's custom Gradle plugin (dev.flutter.flutter-plugin-loader) cannot be
    // resolved by the VS Code Kotlin DSL language server — only by the Flutter toolchain.
    "kotlin.languageServer.enabled": false
}