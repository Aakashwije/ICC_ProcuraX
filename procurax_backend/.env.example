# ===================================================
# ProcuraX Backend — Environment Variables
# ===================================================
# Copy this to .env and fill in your real values.
# On Railway, set these in the Variables tab.
# ===================================================

# Server
PORT=5002
NODE_ENV=production

# MongoDB  (Railway: use MongoDB Atlas connection string)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/procurax?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_jwt_secret_here

# Google Sheets — Service Account
# On Railway: paste the FULL contents of your credentials.json as a single-line JSON string
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# Fallback (local dev only): path to key file
# GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# Default Google Sheet ID  (optional — users have their own via googleSheetUrl)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# Firebase Admin  (paste full service-account JSON)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Email (Nodemailer)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=your_email@gmail.com
# MAIL_PASS=your_app_password