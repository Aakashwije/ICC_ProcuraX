{
  "name": "backend",
  "version": "1.0.0",
  "description": "ProcuraX Backend API",
  "main": "app.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "npm test -- --testPathPatterns=tests/unit",
    "test:integration": "npm test -- --testPathPatterns=tests/integration",
    "test:security": "npm test -- --testPathPatterns=tests/security",
    "test:performance": "npm test -- --testPathPatterns=tests/performance",
    "test:watch": "npm test -- --watch",
    "test:coverage": "npm test -- --coverage",
    "test:ci": "npm test -- --coverage --ci --forceExit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "firebase-admin": "^13.6.0",
    "googleapis": "^169.0.0",
    "https-proxy-agent": "^7.0.6",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.12.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.0.1"
  }
}
